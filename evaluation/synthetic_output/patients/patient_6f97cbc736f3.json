{
  "patient_id": "patient_6f97cbc736f3",
  "events": [
    {
      "type": "demographics",
      "text": "Patient is a 74-year-old White male of Hispanic ethnicity, height 5'7\", weight 168 lbs, BMI 26.3, never smoker, history of type 2 diabetes mellitus and coronary artery disease, no family history of prostate cancer."
    },
    {
      "type": "diagnosis",
      "text": "At age 65, patient was diagnosed with prostate adenocarcinoma (ICD-O site C61.9, histology 8140/3) on transurethral resection of the prostate performed for benign prostatic hyperplasia symptoms; PSA was 9.1 ng/mL."
    },
    {
      "type": "pathology_report",
      "text": "At age 65, transurethral resection specimen showed incidental Gleason 3+4=7 (Grade Group 2) adenocarcinoma involving approximately 15% of the resected tissue; no perineural invasion."
    },
    {
      "type": "clinical_note",
      "text": "At age 65, staging with bone scan and CT was negative for metastatic disease; patient was staged as cT1bN0M0."
    },
    {
      "type": "clinical_note",
      "text": "At age 65, given the patient's age, comorbidities, and intermediate-risk disease, active surveillance was initially pursued with PSA monitoring every 3 months and repeat biopsy at 1 year."
    },
    {
      "type": "pathology_report",
      "text": "At age 66, surveillance prostate biopsy showed upgrading to Gleason 4+4=8 (Grade Group 4) adenocarcinoma in 5 of 12 cores; treatment was recommended."
    },
    {
      "type": "radiation",
      "text": "At age 66, patient received external beam radiation therapy (VMAT) to the prostate, total dose 78 Gy in 39 fractions, with concurrent ADT."
    },
    {
      "type": "systemic",
      "text": "At age 66, leuprolide 22.5 mg intramuscular every 3 months was initiated concurrent with radiation, planned for 2 years given high-risk features."
    },
    {
      "type": "clinical_note",
      "text": "At age 67, PSA nadir was 0.06 ng/mL on ADT; patient tolerated treatment well aside from grade 1 hot flashes."
    },
    {
      "type": "clinical_note",
      "text": "At age 68, after completing 2 years of ADT, leuprolide was discontinued; PSA was 0.1 ng/mL."
    },
    {
      "type": "clinical_note",
      "text": "At age 70, PSA rose to 3.2 ng/mL with testosterone recovery to 280 ng/dL; biochemical recurrence confirmed."
    },
    {
      "type": "systemic",
      "text": "At age 70, leuprolide 22.5 mg intramuscular every 3 months was restarted for biochemical recurrence."
    },
    {
      "type": "imaging_report",
      "text": "At age 71, PSMA PET/CT performed for rising PSA to 5.8 ng/mL on ADT showed PSMA-avid lesions in the T11 vertebral body and bilateral pelvic bones; no visceral disease."
    },
    {
      "type": "clinical_note",
      "text": "At age 71, serum testosterone was 24 ng/dL with PSA of 5.8 ng/mL, confirming castration-resistant disease with new metastases."
    },
    {
      "type": "diagnosis",
      "text": "At age 71, disease reclassified as metastatic castration-resistant prostate cancer, stage rT1bN0M1b, with new bone metastases to thoracic spine and pelvis on continuous ADT."
    },
    {
      "type": "systemic",
      "text": "At age 71, abiraterone acetate 1000 mg daily with prednisone 5 mg twice daily was added to continued leuprolide for mCRPC."
    },
    {
      "type": "adverse_event",
      "text": "At age 71, patient developed grade 2 hyperglycemia (fasting glucose 246 mg/dL) on abiraterone/prednisone requiring adjustment of diabetic medications; also grade 1 peripheral edema."
    },
    {
      "type": "ngs_report",
      "text": "At age 71, next-generation sequencing (Guardant360) on circulating tumor DNA revealed PTEN homozygous loss, AR amplification, and TP53 Y220C mutation; no BRCA1/2 or ATM alterations; microsatellite stable."
    },
    {
      "type": "clinical_note",
      "text": "At age 72, PSA declined to 1.8 ng/mL on abiraterone; bone pain was manageable with acetaminophen."
    },
    {
      "type": "imaging_report",
      "text": "At age 73, restaging bone scan showed new uptake in the left 5th and 7th ribs and right proximal humerus in addition to known lesions; disease progression."
    },
    {
      "type": "clinical_note",
      "text": "At age 73, PSA rose to 11.4 ng/mL on abiraterone; abiraterone was discontinued."
    },
    {
      "type": "systemic",
      "text": "At age 73, docetaxel 75 mg/m2 intravenously every 3 weeks with prednisone 5 mg twice daily was initiated."
    },
    {
      "type": "adverse_event",
      "text": "At age 73, after cycle 1 of docetaxel, patient developed grade 2 fatigue and grade 1 peripheral neuropathy; also noted worsening glycemic control."
    },
    {
      "type": "radiation",
      "text": "At age 74, palliative radiation therapy 8 Gy in a single fraction was delivered to the right proximal humerus for severe pain limiting arm function."
    },
    {
      "type": "adverse_event",
      "text": "At age 74, patient sustained a compression fracture of T11 vertebral body; was started on denosumab 120 mg subcutaneously every 4 weeks for skeletal-related event prevention."
    }
  ],
