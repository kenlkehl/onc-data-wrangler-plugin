{
  "patient_id": "patient_32e94a53ac42",
  "events": [
    {
      "type": "demographics",
      "text": "Patient is a 62-year-old male of White/Caucasian race with an ECOG performance status of 1"
    },
    {
      "type": "diagnosis",
      "text": "At age 62, patient presented with rapidly enlarging cervical and mediastinal lymphadenopathy, night sweats, and unintentional weight loss of 15 pounds over two months"
    },
    {
      "type": "diagnosis",
      "text": "At age 62, excisional biopsy of a right cervical lymph node demonstrated diffuse large B-cell lymphoma, ICD-O site C77.9, histology code 9680/3"
    },
    {
      "type": "pathology_report",
      "text": "At age 62, pathology report from excisional lymph node biopsy showed diffuse proliferation of large atypical lymphoid cells with high mitotic rate, Ki-67 of 80 percent, immunohistochemistry positive for CD20, CD19, CD10, BCL6, negative for MUM1, consistent with germinal center B-cell (GCB) subtype by Hans algorithm"
    },
    {
      "type": "clinical_note",
      "text": "At age 62, flow cytometry on lymph node specimen showed a monoclonal B-cell population positive for CD20, CD19, CD10, and BCL6, negative for CD5, CD23, and MUM1"
    },
    {
      "type": "ngs_report",
      "text": "At age 62, FISH analysis showed no MYC rearrangement, no BCL2 rearrangement, no BCL6 rearrangement; classified as non-double-hit DLBCL"
    },
    {
      "type": "clinical_note",
      "text": "At age 62, laboratory workup revealed markedly elevated LDH at 485 U/L, CBC showed WBC 9.2, hemoglobin 11.8 g/dL, platelets 198, CMP within normal limits except albumin 3.2 g/dL"
    },
    {
      "type": "imaging_report",
      "text": "At age 62, staging PET/CT demonstrated intensely FDG-avid bilateral cervical, mediastinal, and para-aortic lymphadenopathy with the largest cervical node measuring 6.2 cm, SUVmax 22.4, no extranodal involvement identified"
    },
    {
      "type": "pathology_report",
      "text": "At age 62, bilateral bone marrow biopsy was negative for lymphoma involvement, showing trilineage hematopoiesis with no morphologic or immunophenotypic evidence of disease"
    },
    {
      "type": "diagnosis",
      "text": "At age 62, patient was staged as Ann Arbor Stage III with B symptoms, IPI score 3 (high-intermediate risk) based on age over 60, elevated LDH, and Stage III disease"
    },
    {
      "type": "systemic",
      "text": "At age 62, patient initiated cycle 1 of R-CHOP: rituximab 375 mg/m2, cyclophosphamide 750 mg/m2, doxorubicin 50 mg/m2, vincristine 1.4 mg/m2 capped at 2 mg, and prednisone 100 mg daily for 5 days"
    },
    {
      "type": "adverse_event",
      "text": "At age 62, following cycle 1 of R-CHOP, patient developed grade 2 nausea and grade 1 fatigue managed with ondansetron and supportive care"
    },
    {
      "type": "systemic",
      "text": "At age 62, patient received cycle 2 of R-CHOP with prophylactic pegfilgrastim, tolerated without significant complications"
    },
    {
      "type": "systemic",
      "text": "At age 62, patient received cycle 3 of R-CHOP on schedule with no dose modifications"
    },
    {
      "type": "imaging_report",
      "text": "At age 62, interim PET/CT after 3 cycles of R-CHOP showed significant reduction in FDG uptake across all previously noted sites, largest cervical node decreased to 2.1 cm, Deauville score 3, consistent with partial metabolic response"
    },
    {
      "type": "systemic",
      "text": "At age 62, patient received cycle 4 of R-CHOP without dose modifications"
    },
    {
      "type": "adverse_event",
      "text": "At age 62, after cycle 4, patient reported grade 1 peripheral neuropathy with tingling in fingertips attributed to vincristine"
    },
    {
      "type": "systemic",
      "text": "At age 62, patient received cycle 5 of R-CHOP, vincristine dose maintained as neuropathy remained grade 1"
    },
    {
      "type": "systemic",
      "text": "At age 62, patient completed cycle 6 of R-CHOP without significant adverse events"
    },
    {
      "type": "imaging_report",
      "text": "At age 62, end-of-treatment PET/CT demonstrated complete metabolic response with no residual FDG-avid lymphadenopathy, Deauville score 2, consistent with complete remission"
    },
    {
      "type": "clinical_note",
      "text": "At age 62, patient achieved complete remission after 6 cycles of R-CHOP and was transitioned to surveillance with clinical visits and CT imaging every 3 months"
    },
    {
      "type": "imaging_report",
      "text": "At age 63, surveillance CT of chest, abdomen, and pelvis showed no evidence of recurrent lymphadenopathy or new lesions, consistent with continued complete remission"
    },
    {
      "type": "imaging_report",
      "text": "At age 63, follow-up CT scan at 6 months post-treatment remained negative for recurrence"
    },
    {
      "type": "clinical_note",
      "text": "At age 64, patient remains in complete remission at 18-month follow-up with normal LDH, surveillance imaging transitioned to every 6 months"
    }
  ],
